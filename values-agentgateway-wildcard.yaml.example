# Exact + wildcard public hosts for AgentGateway proxy/MCP.
# Layer over hybrid or external values. Helm renders Ingress (AWS/Azure/GCP)
# or OpenShift Routes; DNS, certificates, and controller settings are
# operator prerequisites — see docs/platform-v2.md.

global:
  domain: "platform.example.com"

agentgateway:
  config:
    # Required for dynamic slug resolution; ingress wildcards alone are not enough.
    gatewayDiscoveryMode: "subdomain"
    gatewayBaseDomain: "llm.platform.example.com"
    mcpBaseDomain: "mcp.platform.example.com"
  ingress:
    # auto → Ingress on AWS/Azure/GCP; native Routes on OpenShift.
    # Set "ingress" on OpenShift to keep networking.k8s.io Ingress.
    resourceType: "auto"
    dataPlane:
      # Empty host ⇒ gateway.<global.domain>
      host: ""
      additionalHosts:
        - "*.llm.platform.example.com"
    mcp:
      # Empty host ⇒ mcp.<global.domain>
      host: ""
      additionalHosts:
        - "*.mcp.platform.example.com"

# Provider checklist (operator-owned):
# - AWS ALB: ACM SANs + DNS for exact hosts and *.llm / *.mcp
# - Azure AGIC 1.5.1+ / App Gateway v2: wildcard-capable cert + DNS
# - GCP: self-managed wildcard TLS Secret (managed certs reject wildcards)
# - OpenShift: IngressController routeAdmission.wildcardPolicy=WildcardsAllowed
