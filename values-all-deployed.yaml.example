# Platform v2 external with every supported optional component enabled.
# External mode self-hosts the control and data planes plus the analytics stack.

global:
  deploymentMode: "external"
  platform: "kubernetes"
  domain: "platform.example.com"
  imageRegistry: ""
  autoGenerateSecrets: true
  preserveExistingSecrets: false
  observability:
    enabled: true
    hostedExport:
      enabled: false
  monitoring:
    enabled: true

infrastructure:
  clickhouse:
    deploy: true

# WIP component; keep disabled until a TrustLens release image is published.
trustlens:
  enabled: false

alertengine:
  enabled: true

firewall:
  firewall:
    enabled: true

watchdog:
  enabled: true
  actions:
    dryRun: true
  enabledCheckIds:
    - clickhouse
    - firewall-health
    - pod-health
    - otel-collector
