# Platform v2 external with every supported optional component enabled.
# External mode self-hosts the control and data planes plus the analytics stack.

global:
  deploymentMode: "external"
  platform: "kubernetes"
  domain: "platform.example.com"
  observability:
    enabled: true
    hostedExport:
      enabled: false
  monitoring:
    enabled: true

alertengine:
  enabled: true

firewall:
  enabled: true
  firewall:
    enabled: true

trustguard:
  firewall:
    enabled: true

watchdog:
  enabled: true
  actions:
    dryRun: true
  enabledCheckIds:
    - clickhouse
    - firewall-health
    - pod-health
    - otel-collector
