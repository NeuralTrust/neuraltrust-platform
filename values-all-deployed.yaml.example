# Platform v2 external with every supported optional component enabled.
# Retired AISPM and SIEM Connector workloads are intentionally absent.
# Kafka is explicitly disabled and never renders in v2.

global:
  platformVersion: "v2"
  deploymentMode: "external"
  platform: "kubernetes"
  domain: "platform.example.com"
  imageRegistry: ""
  autoGenerateSecrets: true
  preserveExistingSecrets: false
  observability:
    enabled: true
    hostedExport:
      enabled: false
  monitoring:
    enabled: true

infrastructure:
  postgresql:
    deploy: true
  redis:
    deploy: true
  clickhouse:
    deploy: true
  kafka:
    deploy: false

# WIP component; keep disabled until a TrustLens release image is published.
trustlens:
  enabled: false

alertengine:
  enabled: true

neuraltrust-firewall:
  firewall:
    enabled: true

neuraltrust-watchdog:
  enabled: true
  actions:
    dryRun: true
  enabledCheckIds:
    - clickhouse
    - firewall-health
    - pod-health
    - otel-collector
