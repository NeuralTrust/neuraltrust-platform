# Platform v2 hybrid on AWS EKS with IPv6 pod networking.
# The in-cluster Redis uses the image's dual-stack defaults. Layer this over
# values-required.yaml.

global:
  deploymentMode: "hybrid"
  platform: "aws"
  domain: "platform.example.com"
  ingress:
    aws:
      scheme: "internet-facing"
      targetType: "ip"
      groupName: "neuraltrust-platform"
      sslRedirect: "443"

dataagent:
  tenantId: ""
  enrolmentToken: ""
