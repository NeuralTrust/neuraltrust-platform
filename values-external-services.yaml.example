# Example: Deploy NeuralTrust with external ClickHouse, Kafka, and PostgreSQL
# This example shows how to configure the chart to use pre-installed infrastructure services
#
# Usage:
#   helm install neuraltrust-platform . -f values-external-services.yaml.example
#
# This example shows:
# - Using external infrastructure services (ClickHouse, Kafka, PostgreSQL)
# - Deploying NeuralTrust components (Control Plane and Data Plane)
# - Deploying TrustGate
# - Using Helm-managed secrets (preserveExistingSecrets: false)
# - Using Ingress for external access (Kubernetes) or Routes (OpenShift)
# - Creating the chart's shared self-signed TLS secret by default
# - Using that shared secret automatically whenever an ingress enables TLS without a secretName

# Global settings
global:
  platform: "kubernetes"        # "aws" | "gcp" | "azure" | "openshift" | "kubernetes"
  domain: "yourdomain.com"      # Set to your base domain. Ingresses auto-derive as <prefix>.<domain>.
  imageRegistry: ""             # Optional: set to your private/mirrored registry to rebrand all images.
  preserveExistingSecrets: false  # Set to true if secrets are pre-generated
  storageClass: ""              # Global storage class for persistent volumes
  ingress:
    tls:
      autoGenerate: true  # Create the shared self-signed TLS secret by default.
      secretName: "neuraltrust-ingress-tls"  # Shared secret used whenever a TLS-enabled ingress omits tls.secretName.

# Infrastructure Components - Use external services
infrastructure:
  clickhouse:
    deploy: false  # Use external ClickHouse
    external:
      host: "clickhouse.clickhouse.svc.cluster.local"  # External ClickHouse service
      port: "8123"
      user: "neuraltrust"
      password: "your-clickhouse-password"  # Define this value
      database: "neuraltrust"
      # Optional: Use secret reference instead of password
      # secretName: "clickhouse"  # Secret containing CLICKHOUSE_PASSWORD
      # secretKey: "admin-password"  # Key in secret for password

  kafka:
    deploy: false  # Use external Kafka
    external:
      bootstrapServers: "kafka-kafka-bootstrap.kafka.svc.cluster.local:9092"
      # Or individual brokers:
      # brokers: ["kafka-0.kafka-headless:9092", "kafka-1.kafka-headless:9092"]
      # Optional: Secret reference for external Kafka credentials (if using SASL)
      # secretName: ""  # Optional
      # secretKey: ""  # Optional

  postgresql:
    # Note: PostgreSQL deployment is controlled by neuraltrust-control-plane.infrastructure.postgresql.deploy below
    # External PostgreSQL connection details are configured in neuraltrust-control-plane.controlPlane.components.postgresql.secrets below
    # The infrastructure.postgresql.external section is no longer used - all PostgreSQL configuration is in the control-plane section

# NeuralTrust Control Plane - Use external PostgreSQL
neuraltrust-control-plane:
  infrastructure:
    postgresql:
      deploy: false  # Use external PostgreSQL (configured in controlPlane.components.postgresql.secrets below)
  controlPlane:
    enabled: true
    components:
      postgresql:
        secrets:
          host: "postgresql.postgresql.svc.cluster.local"  # External PostgreSQL service
          port: "5432"
          user: "neuraltrust"
          password: "your-postgres-password"  # Define this value
          database: "neuraltrust"
      # Hostnames auto-derive from global.domain (api.<domain>, app.<domain>, scheduler.<domain>).
      api:
        enabled: true
        ingress:
          enabled: true  # Use Ingress for external access
          # tls:
          #   enabled: true
          #   secretName: ""  # Empty = use the default shared self-signed secret
      app:
        enabled: true
        ingress:
          enabled: true  # Use Ingress for external access
      scheduler:
        enabled: true
        ingress:
          enabled: true  # Use Ingress for external access

# NeuralTrust Data Plane - Use external ClickHouse and Kafka
neuraltrust-data-plane:
  dataPlane:
    enabled: true
    components:
      clickhouse:
        enabled: false  # External ClickHouse
        host: "clickhouse.clickhouse.svc.cluster.local"  # External ClickHouse service
        port: "8123"
        user: "neuraltrust"
        database: "neuraltrust"
      kafka:
        enabled: false  # External Kafka
      # data-plane API hostname auto-derives as data-plane-api.<global.domain>.
      api:
        enabled: true
        ingress:
          enabled: true  # Use Ingress for external access
          # tls:
          #   enabled: true
          #   secretName: ""  # Empty = use the default shared self-signed secret
      worker:
        enabled: true

# TrustGate - Use external PostgreSQL
trustgate:
  enabled: true
  global:
    env:
      DATABASE_HOST: "postgresql.postgresql.svc.cluster.local"  # External PostgreSQL
      DATABASE_PORT: "5432"
      DATABASE_USER: "postgres"  # Or "trustgate" depending on your setup
      DATABASE_PASSWORD: "your-postgres-password"  # Define this value
      DATABASE_NAME: "trustgate"
      DATABASE_SSL_MODE: "require"  # Use "require" for external PostgreSQL
  # TrustGate Ingress hostnames auto-derive: admin.<global.domain>, gateway.<global.domain>, actions.<global.domain>.
  ingress:
    enabled: true  # Use Ingress for external access
    # Optional:
    # tls:
    #   enabled: true
    #   secretName: ""  # Empty = use the default shared self-signed secret
