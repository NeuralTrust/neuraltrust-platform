# Example: Deploy NeuralTrust with external ClickHouse, Kafka, and PostgreSQL
# This example shows how to configure the chart to use pre-installed infrastructure services
#
# Usage:
#   helm install neuraltrust-platform . -f values-external-services.yaml.example
#
# Pre-create Kafka credentials in the release namespace when using SASL:
#   kubectl create secret generic kafka-credentials \
#     --from-literal=username='neuraltrust' \
#     --from-literal=password='<password>'
#   kubectl create secret generic kafka-broker-ca \
#     --from-file=ca.crt=/path/to/broker-ca-bundle.pem
#
# Or use ./create-secrets.sh with KAFKA_USERNAME, KAFKA_PASSWORD, and
# KAFKA_BROKER_CA_FILE — see SECRETS.md.

# Global settings
global:
  platform: "kubernetes"
  domain: "yourdomain.com"
  imageRegistry: ""
  preserveExistingSecrets: false
  storageClass: ""
  postgresql:
    deploy: false
  ingress:
    tls:
      autoGenerate: true
      secretName: "neuraltrust-ingress-tls"
  # External Kafka — all subcharts read connection/auth/TLS from global.kafka.
  # global.customCaCert (HTTP egress) does not enable Kafka TLS by itself.
  kafka:
    bootstrapServers: "kafka-kafka-bootstrap.kafka.svc.cluster.local:9093"
    auth:
      enabled: true
      mechanism: "SCRAM-SHA-512"
      existingSecret: "kafka-credentials"
      usernameKey: "username"
      passwordKey: "password"
    tls:
      enabled: true
      existingSecret: "kafka-broker-ca"
      caKey: "ca.crt"

infrastructure:
  clickhouse:
    deploy: false
    external:
      host: "clickhouse.clickhouse.svc.cluster.local"
      port: "8123"
      user: "neuraltrust"
      password: "your-clickhouse-password"
      database: "neuraltrust"

  kafka:
    deploy: false

  postgresql:
    deploy: false

neuraltrust-control-plane:
  infrastructure:
    postgresql:
      deploy: false
  controlPlane:
    enabled: true
    components:
      postgresql:
        secrets:
          host: "postgresql.postgresql.svc.cluster.local"
          port: "5432"
          user: "neuraltrust"
          password: "your-postgres-password"
          database: "neuraltrust"
      api:
        enabled: true
        ingress:
          enabled: true
      app:
        enabled: true
        ingress:
          enabled: true
      scheduler:
        enabled: true
        ingress:
          enabled: true

neuraltrust-data-plane:
  dataPlane:
    enabled: true
    components:
      clickhouse:
        enabled: false
        host: "clickhouse.clickhouse.svc.cluster.local"
        port: "8123"
        user: "neuraltrust"
        database: "neuraltrust"
      kafka:
        enabled: true
        connect:
          bootstrapServers: ""
      api:
        enabled: true
        ingress:
          enabled: true
      worker:
        enabled: true

trustgate:
  enabled: true
  # Optional: source only TrustGate PostgreSQL fields from a pre-created Secret
  # while the chart still generates SERVER_SECRET_KEY, firewall keys, Redis
  # internals, and other platform secrets.
  # postgresql:
  #   existingSecret: "trustgate-postgres"
  #   existingSecretKeys:
  #     host: DATABASE_HOST
  #     port: DATABASE_PORT
  #     user: DATABASE_USER
  #     password: DATABASE_PASSWORD
  #     database: DATABASE_NAME
  #     sslMode: DATABASE_SSL_MODE
  #     authMode: DATABASE_AUTH_MODE
  global:
    env:
      DATABASE_HOST: "postgresql.postgresql.svc.cluster.local"
      DATABASE_PORT: "5432"
      DATABASE_USER: "postgres"
      DATABASE_PASSWORD: "your-postgres-password"
      DATABASE_NAME: "trustgate"
      DATABASE_SSL_MODE: "require"
  ingress:
    enabled: true
