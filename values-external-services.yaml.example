# Legacy Platform v1 with external PostgreSQL, ClickHouse, and Kafka.
# Kafka configuration is intentionally v1-only; Kafka never renders in v2.
# Pre-create every referenced Kubernetes Secret.

global:
  platformVersion: "v1"
  platform: "kubernetes"
  domain: "platform.example.com"
  postgresql:
    deploy: false
  kafka:
    bootstrapServers: "kafka.example.com:9093"
    auth:
      enabled: true
      mechanism: "SCRAM-SHA-512"
      existingSecret: "kafka-credentials"
      usernameKey: "username"
      passwordKey: "password"
    tls:
      enabled: true
      existingSecret: "kafka-broker-ca"
      caKey: "ca.crt"

infrastructure:
  postgresql:
    deploy: false
  clickhouse:
    deploy: false
    external:
      host: "clickhouse.example.com"
      port: "8443"
      user: "neuraltrust"
      database: "neuraltrust"
      secretName: "managed-clickhouse"
      secretKey: "password"
  kafka:
    deploy: false

neuraltrust-control-plane:
  infrastructure:
    postgresql:
      deploy: false
  controlPlane:
    enabled: true
    components:
      postgresql:
        secrets:
          host: "postgres.example.com"
          port: "5432"

trustgate:
  enabled: true
  postgresql:
    existingSecret: "trustgate-postgres"

neuraltrust-data-plane:
  dataPlane:
    enabled: true
    components:
      clickhouse:
        host: "clickhouse.example.com"
        port: "8443"
        existingSecret:
          name: "managed-clickhouse"
          key: "password"
      worker:
        enabled: true
      kafka:
        enabled: true
