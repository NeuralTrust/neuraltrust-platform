# Platform v2 hybrid with collector-less hosted observability.
# Pre-create `neuraltrust-observability-token` with key `token`.

global:
  platformVersion: "v2"
  deploymentMode: "hybrid"
  observability:
    enabled: false
    tenantId: "<tenant-id>"
    hostedExport:
      enabled: true
      endpoint: "https://collector.neuraltrust.ai"
      auth:
        tokenSecretName: "neuraltrust-observability-token"
        tokenSecretKey: "token"

neuraltrust-watchdog:
  enabled: true
  actions:
    dryRun: true
  enabledCheckIds:
    - clickhouse
    - firewall-health
    - pod-health
