# Platform v2 hybrid with collector-less hosted observability.
# Layer over values-required.yaml plus a ClickStack token (authToken or
# existingSecret). Pre-create `neuraltrust-observability-token` with key `token`.
# Hybrid has no in-cluster ClickHouse — omit that check id.
# hostedExport endpoint / auth defaults match values.yaml; override only when needed.

global:
  deploymentMode: "hybrid"
  observability:
    enabled: false
    tenantId: "<tenant-id>"
    hostedExport:
      enabled: true
      auth:
        tokenSecretName: "neuraltrust-observability-token"
        # tokenSecretKey defaults to "token"

watchdog:
  enabled: true
  actions:
    dryRun: true
  enabledCheckIds:
    - firewall-health
    - pod-health
