# Platform v2 external with local-only observability.
# Layer over values-v2-external.yaml.example (or any external base). The umbrella
# OTel Collector stays local. The external-only ClickStack collector writes
# product telemetry to ClickHouse.

global:
  deploymentMode: "external"
  observability:
    enabled: true
    hostedExport:
      enabled: false
    sendLogs: false
    sendTraces: true
    collector:
      endpoint: ""
      bufferPVC:
        enabled: false
  monitoring:
    enabled: true
    additionalLabels:
      release: "kube-prometheus-stack"
    interval: 30s

alertengine:
  enabled: true

watchdog:
  enabled: true
  actions:
    dryRun: true
  enabledCheckIds:
    - clickhouse
    - firewall-health
    - pod-health
    - otel-collector
  monitoring:
    scrapeAnnotations:
      enabled: true
    podMonitor:
      enabled: true
      additionalLabels:
        release: "kube-prometheus-stack"
    prometheusRule:
      enabled: true
