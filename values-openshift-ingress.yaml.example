# Platform v2 hybrid on OpenShift using Kubernetes Ingress instead of Routes.
# The referenced TLS Secret must exist in the release namespace.

global:
  platformVersion: "v2"
  deploymentMode: "hybrid"
  platform: "openshift"
  domain: "apps.example.com"
  imageRegistry: ""
  autoGenerateSecrets: true
  security:
    allowInsecureImages: true
  ingress:
    provider: "openshift"
    className: "openshift-default"
    tls:
      autoGenerate: false
      secretName: "platform-wildcard-tls"

infrastructure:
  kafka:
    deploy: false

agentgateway:
  ingress:
    enabled: true
    tls:
      enabled: true

trustguard:
  ingress:
    enabled: true
    tls:
      enabled: true

neuraltrust-data-plane:
  dataPlane:
    components:
      api:
        ingress:
          enabled: true
          tls:
            enabled: true

dataagent:
  tenantId: ""
  enrolmentToken: ""
