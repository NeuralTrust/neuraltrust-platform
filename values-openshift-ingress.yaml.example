# Platform v2 hybrid on OpenShift using Kubernetes Ingress instead of Routes.
# The referenced TLS Secret must exist in the release namespace.
# Supply a ClickStack token (authToken or existingSecret) at install time —
# hybrid render fails closed without one (or with clickstack.enabled: false).

global:
  deploymentMode: "hybrid"
  platform: "openshift"
  domain: "apps.example.com"
  ingress:
    provider: "openshift"
    className: "openshift-default"
    tls:
      autoGenerate: false
      secretName: "platform-wildcard-tls"

agentgateway:
  ingress:
    enabled: true
    # Keep Kubernetes Ingress on OpenShift (default auto uses native Routes).
    resourceType: ingress
    tls:
      enabled: true

trustguard:
  ingress:
    enabled: true
    tls:
      enabled: true

data-plane-api:
  dataPlane:
    components:
      api:
        ingress:
          enabled: true
          tls:
            enabled: true
