# Curated Platform v2 self-monitoring overlay.

global:
  deploymentMode: "hybrid"
  selfMonitoring:
    enabled: true
  observability:
    enabled: true

watchdog:
  enabled: true
  actions:
    dryRun: true
  enabledCheckIds:
    - clickhouse
    - firewall-health
    - pod-health
    - otel-collector
    - cert-renewal
    - log-error-rate
