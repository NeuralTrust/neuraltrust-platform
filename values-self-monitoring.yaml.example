# Curated Platform v2 self-monitoring overlay (hybrid).
# Layer over values-required.yaml plus a ClickStack token (authToken or
# existingSecret). Hybrid has no in-cluster ClickHouse — omit that check id.

global:
  deploymentMode: "hybrid"
  observability:
    enabled: true

watchdog:
  enabled: true
  actions:
    dryRun: true
  enabledCheckIds:
    - firewall-health
    - pod-health
    - otel-collector
    - cert-renewal
    - log-error-rate
