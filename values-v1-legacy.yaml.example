# Explicit legacy Platform v1 topology.
# Use only for existing deployments that have not migrated to Platform v2.

global:
  platformVersion: "v1"
  platform: "kubernetes"
  domain: "platform.example.com"
  autoGenerateSecrets: true

infrastructure:
  postgresql:
    deploy: true
  clickhouse:
    deploy: true
  kafka:
    deploy: true

trustgate:
  enabled: true

neuraltrust-control-plane:
  controlPlane:
    enabled: true

neuraltrust-data-plane:
  dataPlane:
    enabled: true
    components:
      api:
        enabled: true
      worker:
        enabled: true
      kafka:
        enabled: true

# AISPM and SIEM Connector components are retired and intentionally omitted.
