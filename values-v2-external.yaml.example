# Platform v2 external: self-hosted control/data planes and analytics.
# ClickStack OTel Collector, DataCore, and AlertEngine render only in this mode.

global:
  platformVersion: "v2"
  deploymentMode: "external"
  platform: "kubernetes"
  domain: "platform.example.com"
  imageRegistry: ""
  observability:
    hostedExport:
      enabled: false

infrastructure:
  postgresql:
    deploy: true
  redis:
    deploy: true
  clickhouse:
    deploy: true
  kafka:
    deploy: false

alertengine:
  enabled: true

trustlens:
  enabled: false
