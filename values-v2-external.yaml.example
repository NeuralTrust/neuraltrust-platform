# Platform v2 external: self-hosted control/data planes and analytics.
# ClickStack OTel Collector, DataCore, and AlertEngine render only in this mode.

global:
  deploymentMode: "external"
  # Prefer a pre-created Secret (keys default to ONPREM_SUPERADMIN_EMAIL /
  # ONPREM_SUPERADMIN_PASSWORD). Inline email+password still works but enters
  # Helm release history.
  superadmin:
    existingSecret:
      name: "onprem-superadmin"
  platform: "kubernetes"
  domain: "platform.example.com"
  observability:
    hostedExport:
      enabled: false
