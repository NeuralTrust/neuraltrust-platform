# Platform v2 hybrid overlay for a fully-configured deployment.
# Documents the "one Postgres block, one Redis block, per-product DataAgent"
# hybrid contract using pre-created Secrets. Prefer existingSecret for
# DataAgent enrolment (also powers ClickStack egress) and config-sync.
# Product OTLP and config-sync are on by default in hybrid.
#
# Positive product slices (mix with -f; no all-off baseline):
#   values-trustgate.yaml.example
#   values-trustguard.yaml.example
#   values-red-teaming.yaml.example
# External mode ignores global.products and always deploys the full stack.
#
# Never commit real tokens, passwords, or customer identifiers.
# For the minimal starting point, see values-required.yaml.

global:
  deploymentMode: "hybrid"
  platform: "kubernetes" # aws | gcp | azure | openshift | kubernetes
  domain: "platform.example.com"
  products:
    trustgate: true
    trustguard: true
    dataPlane: true

  # One shared PostgreSQL block. Every hybrid workload (TrustGate,
  # TrustGuard, DataAgent, data-plane-api) reads envFrom the rendered
  # postgresql-secrets Secret, so all four connect as the same role to the
  # same database.
  #
  # In-cluster (default): leave deploy: true and host/password empty — the
  # chart renders control-plane-postgresql with user/database = neuraltrust
  # and a generated password.
  #
  # External / managed: set deploy: false and reference a Secret containing
  # DB_HOST, DB_PORT, DB_USER, DB_PASSWORD, DB_NAME, DB_SSL_MODE, and
  # SENSIBLE_PG_DSN. Pre-create the user and database out-of-band; the chart
  # never runs CREATE USER.
  postgresql:
    deploy: false
    existingSecret:
      name: "external-postgresql"

  # One shared Redis block. In-cluster default is passwordless on Service
  # `redis:6379`. For a hosted / TLS-only Redis set deploy: false and
  # reference a Secret with REDIS_HOST, REDIS_PORT, REDIS_PASSWORD, and
  # optional REDIS_USERNAME / REDIS_TLS.
  redis:
    deploy: false
    existingSecret:
      name: "external-redis"

# TrustGate (commercial name; image/repo still agentgateway; K8s names
# agentgateway-*). Nested dataagent so product overlays mix via -f.
agentgateway:
  configSync:
    existingSecret:
      name: "agentgateway-config-sync"
  dataagent:
    enrolment:
      existingSecret:
        name: "dataagent-enrolment-trustgate"

trustguard:
  configSync:
    existingSecret:
      name: "trustguard-config-sync"
  dataagent:
    enrolment:
      existingSecret:
        name: "dataagent-enrolment-trustguard"

# The temporary data-plane-api read shim. In hybrid it defaults to PostgreSQL
# (SQL_DATABASE=postgres) and reuses the shared postgresql-secrets, so nothing
# below is required for the default path.
# data-plane-api:
#   dataPlane:
#     components:
#       api:
#         k8sJobs:
#           enabled: true
