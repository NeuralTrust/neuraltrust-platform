# Platform v2 external with managed PostgreSQL, Redis, and ClickHouse.
# Pre-create the service databases/roles and Kubernetes Secrets before install.
# This file contains endpoints and secret names only; it contains no credentials.
#
# With preserveExistingSecrets=true, pre-create at least:
# - control-plane-secrets: AUTH_SECRET, NEXTAUTH_SECRET,
#   CONTROL_PLANE_JWT_SECRET, TRUSTGATE_JWT_SECRET
# - postgresql-secrets: POSTGRES_HOST, POSTGRES_PORT, POSTGRES_USER, POSTGRES_DB,
#   DATABASE_URL, POSTGRES_PRISMA_URL, SENSIBLE_PG_DSN
#   (and POSTGRES_PASSWORD in password mode)
# - agentgateway-secrets: SERVER_SECRET_KEY, STS_SIGNING_KEY, DB_PASSWORD
# - trustguard-secrets: ADMIN_JWT_SECRET, TRUSTGUARD_TOKEN_SIGNING_SECRET,
#   REDIS_EVENTS_SECRET, DB_PASSWORD
# - trustguard-client-credentials: CLIENT_ID, CLIENT_SECRET
# - data-plane-jwt-secret: DATA_PLANE_JWT_SECRET, REDIS_URL
# - datacore-secrets: AUTH_JWT_HS256_SECRET, CLICKHOUSE_USER
#   (and POSTGRES_PASSWORD in password mode; omit when datacore.database.iamAuth=true)
# - alertengine-secrets: DB_PASSWORD, AUTH_JWT_SECRET, APP_ENCRYPTION_KEY
# - clickstack-collector-secrets: CLICKHOUSE_ENDPOINT, CLICKHOUSE_USER,
#   OTLP_AUTH_TOKEN
# - managed-clickhouse: password (the shared ClickHouse credential referenced below)
# Omit static DB password keys only for services whose IAM mode is supported.
# See SECRETS.md for the complete per-component contract.

global:
  deploymentMode: "external"
  # Optional bootstrap admin (set both; password enters Helm release history):
  # superadmin:
  #   email: "admin@example.com"
  #   password: "change-me"
  platform: "kubernetes"
  domain: "platform.example.com"
  autoGenerateSecrets: false
  preserveExistingSecrets: true
  postgresql:
    deploy: false
    # Connection scalars on global.postgresql are primarily the hybrid shared
    # contract. `deploy` still gates the in-cluster Postgres Deployment in every
    # mode. In external, control-plane-api/app consume the shared
    # postgresql-secrets fed by this block and/or control-plane overlays below.
    # Runtime services keep per-service `*.database` as their identity.
  redis:
    deploy: false
  observability:
    hostedExport:
      enabled: false

infrastructure:
  clickhouse:
    deploy: false
    external:
      host: "clickhouse.example.com"
      port: "8443"
      user: "neuraltrust"
      database: "neuraltrust"
      secretName: "managed-clickhouse"
      secretKey: "password"

agentgateway:
  database:
    host: "postgres.example.com"
    sslMode: "require"
  redis:
    host: "redis.example.com"
    tls: "true"

trustguard:
  database:
    host: "postgres.example.com"
    sslMode: "require"
  redis:
    host: "redis.example.com"
    tls: "true"

alertengine:
  enabled: true
  database:
    host: "postgres.example.com"
    sslMode: "require"
  clickhouse:
    host: "clickhouse.example.com"
    nativePort: 9440
    secure: true
    existingSecret:
      name: "managed-clickhouse"
      key: "password"

datacore:
  database:
    host: "postgres.example.com"
    sslMode: "require"
  clickhouse:
    host: "clickhouse.example.com"
    nativePort: 9440
    tls: true
    existingSecret:
      name: "managed-clickhouse"
      key: "password"

clickstack-otel-collector:
  clickhouse:
    endpoint: "https://clickhouse.example.com:8443"
    existingSecret:
      name: "managed-clickhouse"
      key: "password"

data-plane-api:
  dataPlane:
    components:
      clickhouse:
        host: "clickhouse.example.com"
        port: "8443"
        existingSecret:
          name: "managed-clickhouse"
          key: "password"
      api:
        redis:
          host: "redis.example.com"
          tls: "true"

# Control-plane split (external only). Point both charts at the managed Postgres.
control-plane-api:
  controlPlane:
    components:
      postgresql:
        secrets:
          host: "postgres.example.com"
          port: "5432"

control-plane-app:
  controlPlane:
    components:
      postgresql:
        secrets:
          host: "postgres.example.com"
          port: "5432"
