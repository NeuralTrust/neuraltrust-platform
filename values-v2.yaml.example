# Platform v2 hybrid example.
# Control planes remain in NeuralTrust SaaS; data-plane workloads run locally.
# PostgreSQL and Redis deploy in-cluster by default; analytics live in SaaS, so
# no in-cluster ClickHouse renders in hybrid. The temporary data-plane-api read
# shim runs on PostgreSQL by default (no ClickHouse required).
#
# Hybrid contract: one shared PostgreSQL block, one shared Redis block, and one
# mandatory ClickStack OTLP token drive every hybrid workload. Prefer
# existingSecret references for ClickStack (and for config-sync / DataAgent when
# enrolled). There is no init Job — application migrations own their tables.
#
# Layer over values-required.yaml, or supply a ClickStack token here.

global:
  deploymentMode: "hybrid"
  platform: "kubernetes"
  domain: "platform.example.com"
  # v2 hybrid always dual-writes product data over OTLP to the NeuralTrust SaaS
  # ClickStack collector. The endpoint / protocol / TLS are fixed; only the
  # bearer token is operator-supplied. Prefer existingSecret; authToken is an
  # inline escape hatch. Set enabled: false for an air-gapped install.
  clickstack:
    # authToken: "<CLICKSTACK_OTLP_TOKEN>"
    existingSecret:
      name: "clickstack-otlp-token"
      # key defaults to OTEL_EXPORTER_OTLP_HEADERS
  # Shared hybrid Postgres. Every hybrid workload (AgentGateway, TrustGuard,
  # DataAgent, data-plane-api) envFrom's the rendered postgresql-secrets, so
  # all four connect as ONE role to ONE database. In-cluster default renders
  # control-plane-postgresql with user/database = neuraltrust; set deploy: false
  # and supply host + password (or existingSecret.name) for external / managed
  # PostgreSQL.
  #
  # postgresql:
  #   deploy: true
  #   host: ""              # empty + deploy=true -> in-cluster "control-plane-postgresql"
  #   user: neuraltrust
  #   database: neuraltrust
  #   password: ""          # auto-generated when empty
  #   sslMode: prefer
  #
  # Shared hybrid Redis. Passwordless in-cluster default on Service `redis`.
  # See values-v2-hybrid.yaml.example for a fully-configured overlay.

# data-plane-api read shim. In hybrid it defaults to PostgreSQL (SQL_DATABASE=postgres)
# and reuses the umbrella-managed `postgresql-secrets`, so nothing below is required.
# Uncomment to point it at an EXTERNAL PostgreSQL, or to pin/override the backend.
# data-plane-api:
#   dataPlane:
#     components:
#       api:
#         database:
#           # "" (auto) → PostgreSQL in hybrid. Force with "postgres" or "clickhouse".
#           backend: ""
#           postgresql:
#             # Scalars override the matching key from existingSecret; leave empty
#             # to source them from the Secret. Password is always read from the Secret.
#             host: "postgres.example.com"
#             port: "5432"
#             user: "dataplane"
#             database: "neuraltrust"
#             sslMode: "require"
#             existingSecret:
#               name: "my-external-postgres"   # must contain the password key below
#               keys:
#                 password: "POSTGRES_PASSWORD"
#       # To read from an external ClickHouse instead, set a dotted host here:
#       # clickhouse:
#       #   host: "clickhouse.example.com"

# DataAgent remains absent while enrolment is empty. Configure tenantId and
# either the inline token or an existing Secret together.
# dataagent:
#   tenantId: "<tenant-id>"
#   enrolmentTokenExistingSecret:
#     name: "dataagent-enrolment"
#     key: "ENROLMENT_TOKEN"

# Disable Firewall completely (chart dependency, workloads, TrustGuard client).
firewall:
  enabled: false
  firewall:
    enabled: false
trustguard:
  firewall:
    enabled: false
