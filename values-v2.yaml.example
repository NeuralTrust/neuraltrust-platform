# Platform v2 hybrid example.
# Control planes remain in NeuralTrust SaaS; data-plane workloads run locally.
# PostgreSQL, Redis, and ClickHouse deploy in-cluster by default. Kafka never
# renders in v2.

global:
  platformVersion: "v2"
  deploymentMode: "hybrid"
  platform: "kubernetes"
  domain: "platform.example.com"
  imageRegistry: ""
  autoGenerateSecrets: true
  observability:
    hostedExport:
      enabled: true

infrastructure:
  postgresql:
    deploy: true
  redis:
    deploy: true
  clickhouse:
    deploy: true
  kafka:
    deploy: false

# DataAgent remains absent while enrolment is empty. Configure tenantId and
# either the inline token or an existing Secret together.
dataagent:
  tenantId: ""
  enrolmentToken: ""
  enrolmentTokenExistingSecret:
    name: ""
    key: "ENROLMENT_TOKEN"

trustlens:
  enabled: false

neuraltrust-firewall:
  firewall:
    enabled: false
