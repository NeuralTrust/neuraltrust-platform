# Platform v2 watchdog resources for Google Managed Prometheus.
# Layer over values-required.yaml and values-watchdog.yaml.example.

global:
  platformVersion: "v2"
  deploymentMode: "hybrid"
  platform: "gcp"

neuraltrust-watchdog:
  enabled: true
  monitoring:
    scrapeAnnotations:
      enabled: true
    podMonitor:
      enabled: false
    prometheusRule:
      enabled: false
    podMonitoring:
      enabled: true
      interval: 30s
      scrapeTimeout: 10s
    gmpRules:
      enabled: true
      alertLabels:
        team: "platform"
