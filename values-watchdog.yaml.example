# Detailed Platform v2 watchdog overlay (hybrid).
# Layer over values-required.yaml plus a ClickStack token (authToken or
# existingSecret). Healing remains dry-run until both RBAC and per-check policy
# are approved. Hybrid has no in-cluster ClickHouse — omit that check id.

global:
  deploymentMode: "hybrid"
  observability:
    enabled: true

watchdog:
  enabled: true
  rbac:
    create: true
    watchAllNamespaces: false
    actions:
      restartDeployment:
        enabled: false
  actions:
    dryRun: true
    slack:
      webhookUrl: ""
      existingSecret: "watchdog-notifications"
      secretKey: "webhook"
  runner:
    defaultInterval: 60s
    defaultTimeout: 15s
    failureThreshold: 3
  monitoring:
    scrapeAnnotations:
      enabled: true
    podMonitor:
      enabled: true
      additionalLabels:
        release: "kube-prometheus-stack"
    prometheusRule:
      enabled: true
  enabledCheckIds:
    - firewall-health
    - pod-health
    - otel-collector
    - cert-renewal
